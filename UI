	-- Change tabs via HotBar buttons
	local libery = playerGui:WaitForChild("Libery")
	local mainUI = libery:WaitForChild("MainUI")
	local hotBarList = mainUI:WaitForChild("HotBar"):WaitForChild("HotBarList")

	local function openPanel(panelName)
		for _, frame in pairs(mainUI:GetChildren()) do
			if frame:IsA("Frame") and frame ~= hotBarList.Parent then
				frame.Visible = (frame.Name == panelName)
			end
		end
	end

	for _, button in pairs(hotBarList:GetChildren()) do
		if button:IsA("TextButton") then
			button.MouseButton1Click:Connect(function()
				local label = button:FindFirstChildWhichIsA("TextLabel")
				if label and label.Text ~= "" then
					openPanel(label.Text)
				end
			end)
		end
	end

	local homePanel = mainUI:FindFirstChild("Home")
	if homePanel then
		openPanel("Home")
	end

	-- Copy buttons
	local copyItems = {
		{path = {"Libery","MainUI","Home","KeyInfo","InfoPartnerDiscord","Copy"}, text = "https://discord.gg/jnkie"},
		{path = {"Libery","MainUI","Home","KeyInfo","InfoPartnerWebsite","Copy"}, text = "https://junkie-development.de/"},
		{path = {"Libery","MainUI","Home","KeyInfo","InfoSelfDiscord","Copy"}, text = "https://discord.gg/h4ET2rfMYP"},
		{path = {"Libery","MainUI","Home","KeyInfo","InfoSelfWebsite","Copy"}, text = "https://nexorcheatss.netlify.app/"},
		{path = {"Libery","MainUI","Home","NewsInfo","Copy"}, text = "https://discord.gg/h4ET2rfMYP"}
	}

	for _, item in pairs(copyItems) do
		local current = playerGui
		for _, part in ipairs(item.path) do
			local child = current:WaitForChild(part, 3)
			if not child then
				warn("Missing UI path for copy button:", table.concat(item.path, "/"))
				current = nil
				break
			end
			current = child
		end

		local button = current
		local textToCopy = item.text

		if button and button.MouseButton1Click then
			button.MouseButton1Click:Connect(function()
				if setclipboard then
					setclipboard(textToCopy)
					print("Copied:", textToCopy)
				else
					warn("Copy to clipboard function not available")
				end
			end)
		end
	end

	-- Drag UI
	local UserInputService = game:GetService("UserInputService")
	mainUI.Active = true
	mainUI.Selectable = true

	local dragging = false
	local dragInput
	local dragStart
	local startPos

	local function updateDrag(input)
		local delta = input.Position - dragStart
		mainUI.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end

	mainUI.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = mainUI.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	mainUI.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			updateDrag(input)
		end
	end)

	-- Toggle UI keybind (default Right Shift, editable in Misc -> ToggleUI)
	local toggleKey = Enum.KeyCode.RightShift

	local function keycodeFromText(text)
		local cleaned = tostring(text or ""):gsub("[%[%]]", ""):gsub("%s+", "")
		if cleaned == "" then
			return nil
		end
		local upper = cleaned:upper()
		for _, keyCode in ipairs(Enum.KeyCode:GetEnumItems()) do
			if keyCode.Name:upper() == upper then
				return keyCode
			end
		end
		return nil
	end

	local function displayKeyName(keyCode)
		if keyCode.Name == "RightShift" then return "Right Shift" end
		if keyCode.Name == "LeftShift" then return "Left Shift" end
		if keyCode.Name == "RightControl" then return "Right Ctrl" end
		if keyCode.Name == "LeftControl" then return "Left Ctrl" end
		return keyCode.Name
	end

	local toggleBox
	local miscFrame = mainUI:FindFirstChild("Misc")
	if miscFrame then
		local inner = miscFrame:FindFirstChild("Frame")
		if inner then
			local toggleUI = inner:FindFirstChild("ToggleUI")
			if toggleUI then
				local textBox = toggleUI:FindFirstChildWhichIsA("TextBox", true)
				if textBox then
					toggleBox = textBox
				end
			end
		end
	end

	if toggleBox then
		toggleBox.Text = "[" .. displayKeyName(toggleKey) .. "]"
		toggleBox.FocusLost:Connect(function()
			local newKey = keycodeFromText(toggleBox.Text)
			if newKey then
				toggleKey = newKey
			end
			toggleBox.Text = "[" .. displayKeyName(toggleKey) .. "]"
		end)
	end

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if UserInputService:GetFocusedTextBox() then return end
		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == toggleKey then
			mainUI.Visible = not mainUI.Visible
		end
	end)
end
